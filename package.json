{
  "name": "@dreki-gg/pi-lsp",
  "version": "0.1.0",
  "description": "Language-agnostic LSP code intelligence for pi — diagnostics, hover, definitions, references, symbols, and call hierarchy",
  "keywords": [
    "pi-package"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreki-gg/pi-extensions",
    "directory": "packages/lsp"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint extensions",
    "format": "oxfmt --write extensions",
    "format:check": "oxfmt --check extensions"
  },
  "pi": {
    "extensions": [
      "./extensions/lsp"
    ]
  },
  "devDependencies": {
    "@types/node": "24",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
